# NewsAPI.org — https://newsapi.org (free developer key)
NEWSAPI_KEY=your_newsapi_key_here

# New York Times — https://developer.nytimes.com (free, enable Top Stories API)
NYT_API_KEY=your_nyt_api_key_here

# Groq — https://console.groq.com (free, primary LLM)
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio — https://aistudio.google.com/apikey (free, fallback LLM when Groq is unavailable)
GEMINI_API_KEY=your_google_ai_api_key_here

# The Guardian Open Platform — https://open-platform.theguardian.com/access (free)
GUARDIAN_API_KEY=your_guardian_api_key_here

# Optional: Google sign-in for saved per-user preferences
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
